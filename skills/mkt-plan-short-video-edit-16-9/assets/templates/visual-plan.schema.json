{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claudeclaw.local/skills/mkt-plan-short-video-edit-16-9/visual-plan.schema.json",
  "title": "Visual plan — HyperFrames 16:9 talking-head + slide",
  "type": "object",
  "required": ["workspace_slug", "total_duration", "scenes"],
  "additionalProperties": false,
  "properties": {
    "workspace_slug": { "type": "string", "minLength": 1 },
    "total_duration": { "type": "number", "exclusiveMinimum": 0 },
    "brand": {
      "type": "string",
      "enum": ["claude", "deepseek", "openai", "gemini", "generic"],
      "default": "claude"
    },
    "schema_version": { "type": "string", "default": "1.1" },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/scene" }
    }
  },
  "$defs": {
    "scene": {
      "type": "object",
      "required": [
        "id", "num", "kind", "variant", "start", "end",
        "kicker", "heading", "accent_words", "tier_letter",
        "items", "badges", "broll", "pip_events"
      ],
      "additionalProperties": false,
      "properties": {
        "id":   { "type": "string", "minLength": 1 },
        "num":  { "type": "integer", "minimum": 1 },
        "kind": {
          "type": "string",
          "enum": ["hook", "problem", "fail", "pivot", "solution", "differentiator", "proof", "result", "recap", "cta"]
        },
        "variant": {
          "type": "string",
          "enum": ["tier-row", "chats-stack", "hero-orb", "counter-row", "terminal-row", "stats-3-card", "compare-2-col", "embedded-infographic"]
        },
        "start": { "type": "number", "minimum": 0 },
        "end":   { "type": "number", "minimum": 0 },
        "kicker":  { "type": "string" },
        "heading": { "type": "string" },
        "accent_words": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 6
        },
        "voiceover_anchor": {
          "type": "string",
          "description": "Vietnamese phrase from transcript that should align with the first PIP event."
        },
        "tier_letter": {
          "type": "string",
          "minLength": 1,
          "maxLength": 5,
          "description": "Glowing tier-letter glyph. ≤5 chars. Numerals/symbols/brand keywords win over words."
        },
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/item" },
          "maxItems": 6
        },
        "badges": {
          "type": "array",
          "items": { "$ref": "#/$defs/badge" },
          "maxItems": 4
        },
        "broll": {
          "type": "array",
          "items": { "$ref": "#/$defs/broll" }
        },
        "pip_events": {
          "type": "array",
          "items": { "$ref": "#/$defs/pip_event" }
        },
        "sfx_overrides": {
          "type": "array",
          "items": { "$ref": "#/$defs/sfx_override" },
          "default": []
        },
        "inserts": {
          "type": "array",
          "description": "Density layer — short cutaway shots (0.6-3s) at absolute timestamps within the scene window. Auto-suggested by planner when transcript hits verb/action patterns (gõ, click, kéo, mở, so sánh, trước/sau). Mounted ABOVE scene mount.",
          "items": { "$ref": "#/$defs/insert_clip" },
          "default": []
        },
        "bursts": {
          "type": "array",
          "description": "Density layer — sequence of 2-5 quick visuals (each 0.35-0.6s) chained back-to-back when voiceover enumerates items (ChatGPT, Claude, Gemini; A, B, C; thứ nhất, thứ hai, thứ ba).",
          "items": { "$ref": "#/$defs/burst_clip" },
          "default": []
        },
        "flashes": {
          "type": "array",
          "description": "Density layer — number/keyword pop-ins (0.6-1.2s) triggered when voiceover hits a quantity, percentage, currency, or branded keyword. Renderable as pure CSS or PNG.",
          "items": { "$ref": "#/$defs/flash_clip" },
          "default": []
        }
      }
    },
    "item": {
      "type": "object",
      "required": ["icon", "label"],
      "additionalProperties": false,
      "properties": {
        "icon":  { "type": "string", "description": "Emoji or 1-3 char glyph" },
        "label": { "type": "string", "minLength": 1, "maxLength": 40 }
      }
    },
    "badge": {
      "type": "object",
      "required": ["pos", "color", "icon", "num", "label"],
      "additionalProperties": false,
      "properties": {
        "pos":   { "type": "string", "enum": ["tl", "tr", "bl", "br", "ml", "mr"] },
        "color": { "type": "string", "enum": ["orange", "green", "purple", "cyan", "lime", "rose", "pink", "amber", "violet", "slate"] },
        "icon":  { "type": "string" },
        "num":   { "type": "string", "maxLength": 6 },
        "label": { "type": "string", "maxLength": 40 }
      }
    },
    "broll": {
      "type": "object",
      "required": ["kind", "visual_type", "metaphor", "title_vi", "subtitle_vi", "palette_accents", "layout_description", "placeholder_filename"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["infographic-cream-paper", "screenshot", "typing-animation", "grok-video", "icon-illustration"]
        },
        "visual_type": {
          "type": "string",
          "description": "Slide structure type from visual-thinking-types.md. Drives layout (HyperFrame variant + image-gen prompt).",
          "enum": [
            "before-after", "mind-map", "flowchart", "matrix-2x2", "venn",
            "timeline", "pyramid", "comparison-table", "iceberg", "cycle",
            "funnel", "concept-map", "icon-grid", "number-infographic", "three-pillar"
          ]
        },
        "metaphor": {
          "type": "string",
          "description": "Storytelling illustration from visual-thinking-library.md (composed inside the visual_type structure). 'none' = pure structural diagram, no metaphor.",
          "enum": [
            "dong-ho-cat", "heo-dat-vo-ket-sat", "nga-ba-duong", "canh-cua-mo",
            "oc-sen-ten-lua", "ong-nuoc-flow", "lego-ghep", "bac-thang",
            "coc-day-tran", "but-mau-ket-not", "broken-chain", "magnifying-glass",
            "scale-tilt", "gear-chain", "gift-box-open", "lock-open",
            "light-bulb-off-on", "sleeping-vs-working", "paper-stack-100",
            "robot-orb-with-tasks", "network-graph", "tree-grow",
            "key-fits-lock", "mountain-summit", "gear-jam", "custom", "none"
          ]
        },
        "title_vi":    { "type": "string", "minLength": 1 },
        "subtitle_vi": { "type": "string" },
        "palette_accents": {
          "type": "array",
          "items": { "type": "string", "enum": ["lime", "cyan", "rose", "amber", "violet", "pink", "orange", "green", "slate", "claude-orange", "deepseek-blue"] },
          "minItems": 1,
          "maxItems": 4
        },
        "layout_description": { "type": "string", "minLength": 20 },
        "decorative_elements": { "type": "string" },
        "prompt_path": { "type": "string", "description": "e.g. prompts.md#1" },
        "placeholder_filename": {
          "type": "string",
          "pattern": "^\\d+\\.png$"
        },
        "aspect": { "type": "string", "enum": ["16:9", "16:10", "1:1"], "default": "16:10" },
        "notes": { "type": "string" },
        "html_layer_message": {
          "type": "string",
          "description": "What the HTML composition (HyperFrame variant) carries — usually DATA / SPECS / BRAND LOGOS / NUMBERS. The 'WHAT' layer."
        },
        "image_layer_message": {
          "type": "string",
          "description": "What the cream-paper image carries — usually METAPHOR / EMOTION / VIBE. The 'WHY/FEELS' layer. Different from html_layer_message — they together carry the full message."
        },
        "composition_strategy": {
          "type": "string",
          "enum": ["pip-swap", "side-by-side", "layered-bg", "html-only", "image-only"],
          "default": "pip-swap",
          "description": "How HTML and image layers compose. 'pip-swap' = HTML on default, image fades in during PIP windows (recommended for talking-head + slide). 'side-by-side' = both visible simultaneously. 'layered-bg' = image as semi-transparent bg, HTML overlays. 'html-only' / 'image-only' = single layer."
        }
      }
    },
    "pip_event": {
      "type": "object",
      "required": ["t_in", "t_out", "trigger"],
      "additionalProperties": false,
      "properties": {
        "t_in":    { "type": "number", "minimum": 0 },
        "t_out":   { "type": "number", "minimum": 0 },
        "reason":  { "type": "string" },
        "trigger": {
          "type": "string",
          "enum": ["tier-letter-glow", "key-number-reveal", "metaphor-payoff", "custom"]
        }
      }
    },
    "sfx_override": {
      "type": "object",
      "required": ["name", "t"],
      "additionalProperties": false,
      "properties": {
        "name":   { "type": "string" },
        "t":      { "type": "number", "minimum": 0 },
        "volume": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "insert_clip": {
      "type": "object",
      "required": ["t", "duration", "kind", "asset", "reason"],
      "additionalProperties": false,
      "properties": {
        "t":        { "type": "number", "minimum": 0, "description": "Absolute start time in seconds." },
        "duration": { "type": "number", "minimum": 0.3, "maximum": 4.0 },
        "kind": {
          "type": "string",
          "enum": ["macro-shot", "screen-record", "before-after-wipe", "reaction-cut", "icon-zoom", "ai-stock"],
          "description": "macro-shot = close-up hand/object/icon. screen-record = UI capture overlay. before-after-wipe = 2 frames wipe. reaction-cut = quick reaction beat. icon-zoom = emoji/glyph zoom-in. ai-stock = generic AI image (cream-paper style)."
        },
        "asset":    { "type": "string", "minLength": 1, "description": "Filename like '1a.png' or relative path." },
        "reason":   { "type": "string", "minLength": 1, "description": "Why this cutaway lands here — usually a transcript phrase." },
        "transition": {
          "type": "string",
          "enum": ["cut", "fade", "whip"],
          "default": "fade"
        },
        "prompt_path": { "type": "string", "description": "e.g. prompts.md#scene-2-insert-1" }
      }
    },
    "burst_clip": {
      "type": "object",
      "required": ["t_start", "items", "trigger"],
      "additionalProperties": false,
      "properties": {
        "t_start": { "type": "number", "minimum": 0, "description": "Absolute start time of the first item." },
        "items": {
          "type": "array",
          "minItems": 2,
          "maxItems": 6,
          "items": {
            "type": "object",
            "required": ["asset", "duration"],
            "additionalProperties": false,
            "properties": {
              "asset":    { "type": "string", "minLength": 1 },
              "duration": { "type": "number", "minimum": 0.25, "maximum": 1.2 },
              "label":    { "type": "string", "description": "Optional text overlay (brand name, etc.)." }
            }
          }
        },
        "trigger":  { "type": "string", "description": "Transcript phrase that drives the enumeration." },
        "style": {
          "type": "string",
          "enum": ["logo-strip", "icon-strip", "card-stack", "rapid-cut"],
          "default": "logo-strip"
        },
        "transition": {
          "type": "string",
          "enum": ["cut", "fade", "whip"],
          "default": "cut"
        }
      }
    },
    "flash_clip": {
      "type": "object",
      "required": ["t", "duration", "value", "style", "trigger"],
      "additionalProperties": false,
      "properties": {
        "t":        { "type": "number", "minimum": 0 },
        "duration": { "type": "number", "minimum": 0.4, "maximum": 1.6 },
        "value":    { "type": "string", "minLength": 1, "maxLength": 12, "description": "Short text shown — '+300%', '8h', '10tr', 'AI', '5×'." },
        "style": {
          "type": "string",
          "enum": ["number-burst", "keyword-stamp", "icon-pop", "emoji-rain"],
          "description": "number-burst = animated count-up to value. keyword-stamp = ink-stamp impact. icon-pop = single glyph zoom. emoji-rain = 3-5 emojis fall briefly."
        },
        "trigger":  { "type": "string", "description": "Transcript phrase." },
        "color":    { "type": "string", "enum": ["lime", "amber", "rose", "cyan", "violet", "claude-orange"], "default": "amber" },
        "asset":    { "type": "string", "description": "Optional PNG override; pure CSS render if omitted." }
      }
    }
  }
}
