<template id="fs-lesson-1-template">
  <div data-composition-id="fs-lesson-1" data-start="0" data-width="1080" data-height="1920">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&display=swap"
      rel="stylesheet"
    />

    <style>
      [data-composition-id="fs-lesson-1"] {
        width: 100%;
        height: 100%;
        background: #141413;
        color: #faf9f5;
        position: relative;
        overflow: hidden;
        font-family: 'Be Vietnam Pro', 'Inter', Arial, sans-serif;
      }
      /* Background radial glow (subtle warmth behind NUM) */
      [data-composition-id="fs-lesson-1"] .bg-glow {
        position: absolute;
        top: 50%; left: 50%;
        width: 1100px; height: 1100px;
        margin: -550px 0 0 -550px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(217, 119, 87, 0.18) 0%, rgba(217, 119, 87, 0) 60%);
        z-index: 0;
        pointer-events: none;
      }
      /* Pulse rings behind NUM */
      [data-composition-id="fs-lesson-1"] .ring {
        position: absolute;
        top: 50%; left: 50%;
        width: 480px; height: 480px;
        margin: -240px 0 0 -240px;
        border-radius: 50%;
        border: 2px solid rgba(217, 119, 87, 0.45);
        z-index: 0;
        pointer-events: none;
      }
      /* Corner accent marks */
      [data-composition-id="fs-lesson-1"] .corner {
        position: absolute;
        width: 120px; height: 120px;
        border: 4px solid #d97757;
        z-index: 5;
        pointer-events: none;
      }
      [data-composition-id="fs-lesson-1"] .corner.tl { top: 80px; left: 80px; border-right: none; border-bottom: none; border-radius: 12px 0 0 0; }
      [data-composition-id="fs-lesson-1"] .corner.tr { top: 80px; right: 80px; border-left: none; border-bottom: none; border-radius: 0 12px 0 0; }
      [data-composition-id="fs-lesson-1"] .corner.bl { bottom: 80px; left: 80px; border-right: none; border-top: none; border-radius: 0 0 0 12px; }
      [data-composition-id="fs-lesson-1"] .corner.br { bottom: 80px; right: 80px; border-left: none; border-top: none; border-radius: 0 0 12px 0; }

      [data-composition-id="fs-lesson-1"] .scene-content {
        position: relative;
        width: 100%;
        height: 100%;
        padding: 220px 80px 380px;
        box-sizing: border-box;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        z-index: 2;
      }
      [data-composition-id="fs-lesson-1"] .fs-eyebrow {
        font-weight: 600;
        font-size: 32px;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: #d97757;
        margin-bottom: 18px;
      }
      [data-composition-id="fs-lesson-1"] .fs-num {
        font-weight: 800;
        font-size: 240px;
        line-height: 0.86;
        letter-spacing: -0.05em;
        font-variant-numeric: tabular-nums;
        margin-bottom: 12px;
        color: #d97757;
        position: relative;
      }
      [data-composition-id="fs-lesson-1"] .fs-title {
        font-weight: 800;
        font-size: 130px;
        line-height: 1.1;
        letter-spacing: -0.02em;
        margin: 0 0 24px;
      }
      [data-composition-id="fs-lesson-1"] .fs-title .word {
        display: inline-block;
        will-change: transform, opacity;
      }
      [data-composition-id="fs-lesson-1"] .fs-title .accent { color: #d97757; }
      [data-composition-id="fs-lesson-1"] .fs-sub {
        font-style: italic;
        font-weight: 500;
        font-size: 38px;
        line-height: 1.35;
        max-width: 800px;
        opacity: 0.74;
        margin-top: 6px;
      }
    </style>

    <div class="bg-glow"></div>
    <div class="ring ring-1"></div>
    <div class="ring ring-2"></div>
    <div class="ring ring-3"></div>

    <div class="corner tl"></div>
    <div class="corner tr"></div>
    <div class="corner bl"></div>
    <div class="corner br"></div>

    <div class="scene-content">
      <div class="fs-eyebrow">Bài học #1</div>
      <div class="fs-num">01</div>
      <div class="fs-title">
        <span class="word">Dám</span>
        <span class="word">đẩy</span>
        <span class="word">bản</span><br />
        <span class="word accent">thử</span>
        <span class="word accent">nghiệm</span>
        <span class="word">ra</span>
      </div>
      <div class="fs-sub">Don't wait for perfect — ship beta &amp; xin feedback</div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/gsap@3.14.2/dist/gsap.min.js"></script>
    <script>
      window.__timelines = window.__timelines || {};
      const tl = gsap.timeline({ paused: true });
      const ROOT = '[data-composition-id="fs-lesson-1"]';

      // Punch-zoom entrance on the whole scene content
      tl.from(ROOT + ' .scene-content', {
        scale: 1.12, opacity: 0, duration: 0.42, ease: "back.out(1.5)",
      }, 0);

      // Background glow fade in
      tl.from(ROOT + ' .bg-glow', {
        opacity: 0, scale: 0.7, duration: 0.8, ease: "power2.out",
      }, 0.1);

      // Corner marks draw in (4 corners stagger)
      tl.from(ROOT + ' .corner', {
        scale: 0, opacity: 0, duration: 0.5, ease: "back.out(2)",
        stagger: 0.06,
      }, 0.2);

      // Eyebrow + NUM
      tl.from(ROOT + ' .fs-eyebrow', {
        y: -22, opacity: 0, duration: 0.45, ease: "power3.out",
      }, 0.25);
      tl.from(ROOT + ' .fs-num', {
        scale: 0.5, opacity: 0, rotation: -8, duration: 0.65, ease: "back.out(1.6)",
      }, 0.35);

      // Title — slam each word from above with stagger
      tl.from(ROOT + ' .fs-title .word', {
        y: -50, opacity: 0, scale: 1.6,
        duration: 0.5, ease: "back.out(1.8)",
        stagger: 0.07,
      }, 0.55);

      // Sub fade in
      tl.from(ROOT + ' .fs-sub', {
        y: 22, opacity: 0, duration: 0.5, ease: "power2.out",
      }, 1.0);

      // ===== AMBIENT EFFECTS (during scene) =====
      // 1) NUM breath pulse
      const numCycle = 1.4;
      const numRepeats = Math.max(1, Math.ceil(2.0 / numCycle) - 1);
      tl.to(ROOT + ' .fs-num', {
        scale: 1.05,
        duration: numCycle / 2,
        ease: "sine.inOut",
        yoyo: true,
        repeat: numRepeats,
      }, 1.2);

      // 2) Pulse rings expanding outward (3 rings staggered)
      [0, 0.5, 1.0].forEach((delay, idx) => {
        const ringSel = ROOT + ' .ring-' + (idx + 1);
        const cycleSec = 1.5;
        const cycleRepeats = Math.max(1, Math.ceil(2.5 / cycleSec) - 1);
        tl.fromTo(ringSel,
          { scale: 0.5, opacity: 0.6 },
          { scale: 2.4, opacity: 0, duration: cycleSec, ease: "power2.out", repeat: cycleRepeats },
          0.6 + delay
        );
      });

      // 3) Sub continuous gentle drift (sine wave)
      tl.to(ROOT + ' .fs-sub', {
        y: -6,
        duration: 1.4,
        ease: "sine.inOut",
        yoyo: true,
        repeat: 1,
      }, 1.5);

      window.__timelines["fs-lesson-1"] = tl;
    </script>
  </div>
</template>
