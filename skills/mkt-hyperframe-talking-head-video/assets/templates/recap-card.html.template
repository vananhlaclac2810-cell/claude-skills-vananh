<template id="recap-card-template">
  <div data-composition-id="recap-card" data-start="0" data-width="1080" data-height="1920">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:ital,wght@0,400;0,500;0,600;0,700;0,800&display=swap"
      rel="stylesheet"
    />

    <style>
      [data-composition-id="recap-card"] {
        width: 100%;
        height: 100%;
        background: transparent;
        position: relative;
        overflow: hidden;
        font-family: 'Be Vietnam Pro', 'Inter', Arial, sans-serif;
      }
      [data-composition-id="recap-card"] .scene-content {
        width: 100%;
        height: 100%;
        padding: 200px 80px 380px;
        box-sizing: border-box;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-start;
      }
      [data-composition-id="recap-card"] .recap-card-inner {
        width: 920px;
        max-width: 100%;
        display: flex;
        flex-direction: column;
        gap: 14px;
        padding: 32px 36px;
        background: rgba(250, 249, 245, 0.96);
        border-radius: 24px;
        box-shadow: 0 16px 48px rgba(20, 20, 19, 0.32);
        box-sizing: border-box;
      }
      [data-composition-id="recap-card"] .recap-eyebrow {
        font-weight: 600;
        font-size: 28px;
        letter-spacing: 0.16em;
        color: #d97757;
        text-transform: uppercase;
        margin-bottom: 6px;
      }
      [data-composition-id="recap-card"] .recap-row {
        display: flex;
        align-items: center;
        gap: 18px;
        padding: 14px 18px;
        background: #e8e6dc;
        border-radius: 14px;
      }
      [data-composition-id="recap-card"] .recap-row .num {
        font-weight: 700;
        font-size: 36px;
        color: #d97757;
        width: 56px;
        text-align: center;
        font-variant-numeric: tabular-nums;
      }
      [data-composition-id="recap-card"] .recap-row .text {
        font-weight: 600;
        font-size: 32px;
        line-height: 1.2;
        color: #141413;
      }
    </style>

    <div class="scene-content">
      <div class="recap-card-inner">
        <div class="recap-eyebrow">Tổng kết · 3 bài học</div>
        <div class="recap-row">
          <div class="num">01</div>
          <div class="text">Dám đẩy bản thử nghiệm</div>
        </div>
        <div class="recap-row">
          <div class="num">02</div>
          <div class="text">Rút ngắn đường tới user</div>
        </div>
        <div class="recap-row">
          <div class="num">03</div>
          <div class="text">Bỏ thói quen tự xin phép</div>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/gsap@3.14.2/dist/gsap.min.js"></script>
    <script>
      window.__timelines = window.__timelines || {};
      const tl = gsap.timeline({ paused: true });
      const ROOT = '[data-composition-id="recap-card"]';

      // Card entrance — slide-up + scale soft
      tl.from(ROOT + ' .recap-card-inner', {
        y: 50, opacity: 0, scale: 0.96, duration: 0.6, ease: "power3.out",
      }, 0.15);
      tl.from(ROOT + ' .recap-eyebrow', {
        opacity: 0, x: -30, duration: 0.5, ease: "power2.out",
      }, 0.4);
      tl.from(ROOT + ' .recap-row', {
        x: 60, opacity: 0, duration: 0.5, ease: "power4.out", stagger: 0.18,
      }, 0.65);

      window.__timelines["recap-card"] = tl;
    </script>
  </div>
</template>
