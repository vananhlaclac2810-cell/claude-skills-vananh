{# Captions overlay composition for the 16:9 video pipeline.

   Variables:
     captions_json (str)  — JSON-serialized list of {text, start, end} dicts (Vietnamese-safe).

   Style is CONSTANT across videos (modern AI editorial — dark pill, violet
   border, Inter 600 38px, bottom-center of 1920×1080 stage). Only the data
   array changes per video. Render via tools/templates/captions.html.j2 with
   captions_json injected.
#}<template id="captions-template">
  <div data-composition-id="captions" data-start="0" data-width="1920" data-height="1080">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@500;600;700&display=block" rel="stylesheet" />

    <style>
      [data-composition-id="captions"] {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        background: transparent;
        font-family: "Inter", -apple-system, BlinkMacSystemFont, sans-serif;
        -webkit-font-smoothing: antialiased;
      }

      [data-composition-id="captions"] .caption-stack {
        position: absolute;
        left: 50%;
        bottom: 200px;
        transform: translateX(-50%);
        width: 1200px;
        max-width: 1200px;
        pointer-events: none;
      }

      [data-composition-id="captions"] .caption-line {
        position: absolute;
        bottom: 0;
        left: 50%;
        transform: translateX(-50%);
        opacity: 0;
        will-change: opacity, transform;
        width: max-content;
        max-width: 900px;
        padding: 14px 26px;
        background: rgba(0, 0, 0, 0.78);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1.5px solid rgba(167, 139, 250, 0.40);
        border-radius: 14px;
        box-shadow:
          0 8px 30px rgba(0, 0, 0, 0.6),
          0 0 24px rgba(167, 139, 250, 0.18);
        font-family: "Inter", sans-serif;
        font-weight: 600;
        font-size: 28px;
        line-height: 1.30;
        letter-spacing: -0.015em;
        color: #f5f5f7;
        text-align: center;
        text-shadow: 0 2px 12px rgba(0, 0, 0, 0.85);
        white-space: normal;
        word-wrap: break-word;
      }
    </style>

    <div class="caption-stack" id="caption-stack"></div>

    <script>
      window.__timelines = window.__timelines || {};
      (function () {
        const R = '[data-composition-id="captions"]';
        const root = document.currentScript.closest(R)
          || document.querySelector(R);
        if (!root) return;

        const CAPTIONS = {{ captions_json }};

        const FADE = 0.18;
        const stack = root.querySelector('#caption-stack');
        const lines = CAPTIONS.map(c => {
          const el = document.createElement('div');
          el.className = 'caption-line';
          el.textContent = c.text;
          stack.appendChild(el);
          return el;
        });

        const tl = gsap.timeline({ paused: true });
        CAPTIONS.forEach((c, i) => {
          const el = lines[i];
          tl.fromTo(el,
            { opacity: 0, y: 10 },
            { opacity: 1, y: 0, duration: FADE, ease: 'power2.out' },
            c.start);
          const fadeOutAt = Math.max(c.start + FADE, c.end - FADE);
          tl.to(el, { opacity: 0, duration: FADE, ease: 'power2.in' }, fadeOutAt);
          // Hard kill at the very end so a stuck tween can't leave the pill on screen
          tl.set(el, { opacity: 0 }, c.end);
        });
        window.__timelines["captions"] = tl;
      })();
    </script>
  </div>
</template>
