{# tier-row pattern — Hook (BEFORE/AFTER) and recap-mini.
   Vars: id, kicker, heading_words (list), eyebrow_color (hex), grad_pair (2 hex),
         before_letter, before_label, before_items[{icon,label}],
         after_letter,  after_label,  after_items[{icon,label}],
         after_tool_badge (optional {logo, name}) — pill at top-right of "after" row,
           e.g. {logo: 'assets/logos/claude.png', name: 'CLAUDE'}.
         duration (seconds, for data-duration on root).
#}
<template id="{{ id }}-template">
  <div data-composition-id="{{ id }}" data-start="0" data-width="1200" data-height="1080">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
    <style>
      [data-composition-id="{{ id }}"] {
        width: 100%; height: 100%;
        background: #000; color: #f5f7fa;
        position: relative; overflow: hidden;
        font-family: 'Inter', sans-serif;
        -webkit-font-smoothing: antialiased;
      }
      [data-composition-id="{{ id }}"] .bg-glow {
        position: absolute; inset: 0; z-index: 0;
        background:
          radial-gradient(ellipse 600px 400px at 30% 35%, rgba(251,113,133,0.10), transparent 60%),
          radial-gradient(ellipse 600px 400px at 70% 75%, rgba(163,230,53,0.10), transparent 60%);
      }
      [data-composition-id="{{ id }}"] .stage {
        position: relative; z-index: 5;
        width: 100%; height: 100%;
        padding: 130px 70px 80px;
        box-sizing: border-box;
        display: flex; flex-direction: column;
        gap: 32px;
      }
      [data-composition-id="{{ id }}"] .eyebrow {
        font-family: 'JetBrains Mono', monospace;
        font-size: 16px; font-weight: 600;
        letter-spacing: 0.22em; text-transform: uppercase;
        color: {{ eyebrow_color | default('#67e8f9') }};
        display: inline-flex; align-items: center; gap: 12px;
        align-self: flex-start;
      }
      [data-composition-id="{{ id }}"] .eyebrow .live {
        width: 8px; height: 8px; border-radius: 50%;
        background: {{ eyebrow_color | default('#67e8f9') }};
        box-shadow: 0 0 12px {{ eyebrow_color | default('#67e8f9') }};
      }
      [data-composition-id="{{ id }}"] .title {
        font-weight: 800; font-size: 84px; line-height: 0.96;
        letter-spacing: -0.035em;
        margin: 0; will-change: transform, opacity;
      }
      [data-composition-id="{{ id }}"] .title .word { display: inline-block; margin-right: 0.18em; will-change: transform, opacity; }
      [data-composition-id="{{ id }}"] .title .grad-l {
        background: linear-gradient(135deg, {{ grad_pair[0] | default('#a3e635') }}, {{ grad_pair[1] | default('#67e8f9') }});
        -webkit-background-clip: text; background-clip: text; color: transparent;
      }
      [data-composition-id="{{ id }}"] .rows { display: flex; flex-direction: column; gap: 18px; margin-top: 12px; }
      [data-composition-id="{{ id }}"] .tier-row {
        display: grid; grid-template-columns: 140px 1fr; gap: 20px;
        background: rgba(15, 20, 30, 0.55);
        border: 1.5px solid rgba(103, 232, 249, 0.30);
        border-radius: 20px;
        padding: 20px 24px;
        backdrop-filter: blur(14px);
        box-shadow: 0 0 32px rgba(103, 232, 249, 0.10), inset 0 1px 0 rgba(255,255,255,0.04);
        align-items: center;
        will-change: transform, opacity;
      }
      [data-composition-id="{{ id }}"] .tier-letter {
        font-weight: 900; font-size: 88px; letter-spacing: -0.04em;
        line-height: 1; text-align: center;
        font-variant-numeric: tabular-nums;
      }
      [data-composition-id="{{ id }}"] .tier-row.before .tier-letter { color: #fb7185; text-shadow: 0 0 28px rgba(251,113,133,0.85), 0 0 12px rgba(251,113,133,0.6); }
      [data-composition-id="{{ id }}"] .tier-row.after  .tier-letter { color: #a3e635; text-shadow: 0 0 28px rgba(163,230,53,0.85), 0 0 12px rgba(163,230,53,0.6); }
      [data-composition-id="{{ id }}"] .tier-row.after { border-color: rgba(163,230,53,0.40); box-shadow: 0 0 32px rgba(163,230,53,0.16), inset 0 1px 0 rgba(255,255,255,0.04); }
      [data-composition-id="{{ id }}"] .tier-content { display: flex; flex-direction: column; gap: 8px; }
      [data-composition-id="{{ id }}"] .tier-label {
        font-family: 'JetBrains Mono', monospace;
        font-size: 13px; font-weight: 700;
        letter-spacing: 0.18em; text-transform: uppercase;
        color: #8b94a8;
      }
      [data-composition-id="{{ id }}"] .tier-row.before .tier-label { color: #fb7185; }
      [data-composition-id="{{ id }}"] .tier-row.after  .tier-label { color: #a3e635; }
      [data-composition-id="{{ id }}"] .items { display: flex; gap: 14px; flex-wrap: wrap; }
      [data-composition-id="{{ id }}"] .item { display: flex; flex-direction: column; align-items: center; gap: 4px; min-width: 90px; }
      [data-composition-id="{{ id }}"] .item .ic {
        width: 60px; height: 60px;
        display: inline-flex; align-items: center; justify-content: center;
        font-size: 32px;
        background: rgba(255,255,255,0.04);
        border-radius: 14px; border: 1px solid rgba(255,255,255,0.10);
        filter: drop-shadow(0 0 8px rgba(255,255,255,0.15));
      }
      [data-composition-id="{{ id }}"] .item .lb { font-size: 13px; color: #c4cad6; font-weight: 500; text-align: center; }
      [data-composition-id="{{ id }}"] .tier-row.after .item .ic { background: rgba(163,230,53,0.08); border-color: rgba(163,230,53,0.30); filter: drop-shadow(0 0 10px rgba(163,230,53,0.35)); }
      [data-composition-id="{{ id }}"] .tier-row { position: relative; }
      [data-composition-id="{{ id }}"] .tool-badge {
        position: absolute; top: 14px; right: 18px;
        display: inline-flex; align-items: center; gap: 8px;
        padding: 6px 12px 6px 6px;
        background: rgba(255,255,255,0.95);
        border-radius: 999px;
        box-shadow: 0 4px 16px rgba(163,230,53,0.30);
      }
      [data-composition-id="{{ id }}"] .tool-badge img { width: 28px; height: 28px; object-fit: contain; }
      [data-composition-id="{{ id }}"] .tool-badge .tool-name { font-family: 'JetBrains Mono', monospace; font-size: 13px; font-weight: 700; letter-spacing: 0.10em; color: #1a1a1a; }
    </style>
    <div class="bg-glow"></div>
    <div class="stage">
      <span class="eyebrow"><span class="live"></span>{{ kicker }}</span>
      <h1 class="title">
        {%- for w in heading_words -%}
        <span class="word{% if w.grad %} grad-l{% endif %}">{{ w.text }}</span>
        {%- endfor -%}
      </h1>
      <div class="rows">
        <div class="tier-row before">
          <div class="tier-letter">{{ before_letter }}</div>
          <div class="tier-content">
            <span class="tier-label">{{ before_label }}</span>
            <div class="items">
              {%- for it in before_items -%}
              <div class="item"><div class="ic">{{ it.icon }}</div><div class="lb">{{ it.label }}</div></div>
              {%- endfor -%}
            </div>
          </div>
        </div>
        <div class="tier-row after">
          <div class="tier-letter">{{ after_letter }}</div>
          <div class="tier-content">
            <span class="tier-label">{{ after_label }}</span>
            <div class="items">
              {%- for it in after_items -%}
              <div class="item"><div class="ic">{{ it.icon }}</div><div class="lb">{{ it.label }}</div></div>
              {%- endfor -%}
            </div>
          </div>
          {%- if after_tool_badge -%}
          <div class="tool-badge"><img src="{{ after_tool_badge.logo }}" alt="{{ after_tool_badge.name }}"><span class="tool-name">{{ after_tool_badge.name }}</span></div>
          {%- endif -%}
        </div>
      </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.14.2/dist/gsap.min.js"></script>
    <script>
      window.__timelines = window.__timelines || {};
      const tl = gsap.timeline({ paused: true });
      const R = '[data-composition-id="{{ id }}"]';
      tl.from(R + ' .eyebrow', { y: -20, opacity: 0, duration: 0.5, ease: 'power3.out' }, 0.1);
      tl.from(R + ' .title .word', { y: 50, opacity: 0, scale: 0.85, duration: 0.55, ease: 'back.out(1.6)', stagger: 0.07 }, 0.4);
      tl.from(R + ' .tier-row.before', { x: -60, opacity: 0, duration: 0.55, ease: 'power3.out' }, 1.5);
      tl.from(R + ' .tier-row.before .tier-letter', { scale: 0, opacity: 0, duration: 0.5, ease: 'back.out(1.8)' }, 1.8);
      tl.from(R + ' .tier-row.before .item', { y: 20, opacity: 0, duration: 0.4, stagger: 0.12 }, 2.2);
      tl.from(R + ' .tier-row.after', { x: -60, opacity: 0, duration: 0.55, ease: 'power3.out' }, 5.5);
      tl.from(R + ' .tier-row.after .tier-letter', { scale: 0, opacity: 0, duration: 0.5, ease: 'back.out(1.8)' }, 5.9);
      tl.from(R + ' .tier-row.after .item', { y: 20, opacity: 0, duration: 0.4, stagger: 0.12 }, 6.4);
      tl.to(R + ' .tier-row.after', { boxShadow: '0 0 60px rgba(163,230,53,0.35), inset 0 1px 0 rgba(255,255,255,0.04)', duration: 1.2, ease: 'sine.inOut', yoyo: true, repeat: 4 }, 8.0);
      window.__timelines["{{ id }}"] = tl;
    </script>
{{ infographic_slot | default('') }}
  </div>
</template>
